---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="mb-16">
  <h2 class="text-2xl font-bold text-slate-900 mb-6 pb-2 border-b border-slate-200">
    {title}
  </h2>
  <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed space-y-4 font-normal">
    <slot />
  </div>
</section>
