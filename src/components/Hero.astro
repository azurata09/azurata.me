---
import { Image } from 'astro:assets';
import userIcon from '../assets/icon.png';

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<header class="mb-24 py-12 flex flex-col md:flex-row items-center justify-center gap-10 text-center md:text-left">
  <div class="shrink-0">
    <Image 
      src={userIcon} 
      alt={name} 
      width={160} 
      height={160} 
      class="rounded-full border-4 border-white shadow-xl bg-white transition-transform hover:scale-105 duration-300"
    />
  </div>
  <div class="flex flex-col">
    <h1 class="text-5xl font-bold text-slate-900 mb-8 tracking-tight leading-tight">{name}</h1>
    <div class="flex justify-center md:justify-start gap-8">
      <a href="https://github.com/azurata09" class="group flex items-center gap-2 text-slate-600 hover:text-slate-900 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:scale-110"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        <span class="text-sm font-semibold uppercase tracking-widest">GitHub</span>
      </a>
      <a href="https://twitter.com/azurata09_" class="group flex items-center gap-2 text-slate-600 hover:text-blue-400 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:scale-110"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        <span class="text-sm font-semibold uppercase tracking-widest">X / Twitter</span>
      </a>
    </div>
  </div>
</header>
