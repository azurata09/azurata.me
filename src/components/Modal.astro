---
interface Props {
  id: string;
  title: string;
  techStack?: string[];
  github?: string;
  url?: string;
  githubLabel?: string;
  urlLabel?: string;
}

const { id, title, techStack, github, url, githubLabel = "GitHub", urlLabel = "Live Demo" } = Astro.props;
---

<dialog id={`modal-${id}`} class="fixed inset-0 m-auto rounded-2xl p-0 backdrop:bg-slate-900/50 w-[calc(100%-2rem)] max-w-2xl h-fit max-h-[90vh] overflow-hidden shadow-2xl border-0 bg-white">
  <div class="flex flex-col h-full max-h-[90vh]">
    <header class="p-6 border-b border-slate-100 flex justify-between items-center sticky top-0 bg-white z-10">
      <h3 class="text-xl font-bold text-slate-900">{title}</h3>
      <button class="close-modal text-slate-400 hover:text-slate-600 p-2" data-modal-id={`modal-${id}`}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </header>
    <div class="p-8 overflow-y-auto">
      {techStack && (
        <div class="flex flex-wrap gap-2 mb-6">
          {techStack.map((tech: string) => (
            <span class="px-3 py-1 bg-blue-50 text-blue-700 text-xs rounded-full font-semibold">{tech}</span>
          ))}
        </div>
      )}
      <div class="prose prose-slate max-w-none prose-sm sm:prose-base text-slate-700 whitespace-pre-wrap">
        <slot />
      </div>
      {(github || url) && (
        <div class="mt-10 flex gap-4 border-t border-slate-100 pt-6">
          {github && (
            <a href={github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-slate-900 text-white rounded-lg text-sm font-medium hover:bg-slate-800 transition-colors">
              {githubLabel}
            </a>
          )}
          {url && (
            <a href={url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
              {urlLabel}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</dialog>
