---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import userIcon from '../assets/icon.png';

// データの取得
const education = await getCollection('education');
const experience = await getCollection('experience');

// リスト形式のデータ（単一ファイルから取得）
const certificationsEntry = await getEntry('certifications', 'list');
const certifications = (certificationsEntry?.data || []).map((item: any, index: number) => ({ ...item, id: `cert-${index}` }));

const awardsEntry = await getEntry('awards', 'list');
const awards = (awardsEntry?.data || []).map((item: any, index: number) => ({ ...item, id: `award-${index}` }));

const presentationsEntry = await getEntry('presentations', 'list');
const presentations = (presentationsEntry?.data || []).map((item: any, index: number) => ({ ...item, id: `pres-${index}` }));

const projects = await getCollection('projects');
const sortedProjects = await Promise.all(
  projects
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (project) => {
      const { Content } = await render(project);
      return { ...project, Content };
    })
);

const name = "あずらた";
const englishName = "azurata";
---

<Layout title={`${name} | Portfolio`}>
	{/* Hero Section */}
	<header class="mb-24 py-12 flex flex-col md:flex-row items-center justify-center gap-10 text-center md:text-left">
    <div class="shrink-0">
      <Image 
        src={userIcon} 
        alt={name} 
        width={160} 
        height={160} 
        class="rounded-full border-4 border-white shadow-xl bg-white transition-transform hover:scale-105 duration-300"
      />
    </div>
    <div class="flex flex-col">
		  <h1 class="text-5xl font-bold text-slate-900 mb-1 tracking-tight leading-tight">{name}</h1>
		  <p class="text-2xl text-slate-500 mb-8 font-medium tracking-wide">{englishName}</p>
		  <div class="flex justify-center md:justify-start gap-8">
			  <a href="https://github.com/azurata09" class="group flex items-center gap-2 text-slate-600 hover:text-slate-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:scale-110"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span class="text-sm font-semibold uppercase tracking-widest">GitHub</span>
        </a>
			  <a href="https://twitter.com/azurata09_" class="group flex items-center gap-2 text-slate-600 hover:text-blue-400 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:scale-110"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          <span class="text-sm font-semibold uppercase tracking-widest">X / Twitter</span>
        </a>
		  </div>
    </div>
	</header>

	{/* About Section */}
	<section class="mb-16">
		<h2 class="text-2xl font-bold text-slate-900 mb-6 pb-2 border-b border-slate-200">自己紹介</h2>
		<div class="prose prose-slate max-w-none text-slate-700 leading-relaxed space-y-4 font-normal">
			<p>
				私は公立はこだて未来大学で情報科学を学んでいる学生です。大学では知能システムコースに属しています。2025年度からは<a href="https://www.lab-ish.com" class="text-blue-600 hover:underline">稲村・石田研究室</a>に属しており、ストレス推定によるタスク管理の自動化について取り組んでいます（主指導教員: 石田繁巳 准教授）。興味のある分野は、ユビキタスコンピューティング、ストレス推定などです。
			</p>
			<p>
				これまで、Webアプリケーションの開発・組み込みシステムの開発・プロジェクトマネジメントの3分野に取り組んできました。フロントエンドでは、Vue.jsやReactをTypeScriptで実装することを得意としており、バックエンド開発ではJavaScript、TypeScript、Pythonを用いることが多いです。また、UMLを活用したソフトウェア設計経験もあります。プロジェクトマネジメントでは、多くのチームでプロダクトの提案・チームリードを行ってきました。
			</p>
			<p>
				私の強みは、主体的に行動し、自ら学び挑戦し続ける姿勢です。どのチームに属しても、何か判断をするときは「なぜこういう実装・判断になっているのか」を重要視し、自分のなかで納得ができるまで学びます。加えて、技術的なスキルを磨くだけでなく、プロジェクトの目的や意義を理解し、チームで協力しながら成果を生み出すことを大切にしています。
			</p>
		</div>
	</section>

	{/* Experience & Education Section */}
	<div class="grid md:grid-cols-2 gap-12 mb-16">
		<section>
			<h2 class="text-2xl font-bold text-slate-900 mb-6 pb-2 border-b border-slate-200">学歴</h2>
			<div class="space-y-6">
				{education.map(item => (
					<div class="relative pl-4 border-l-2 border-slate-200">
						<span class="text-sm text-slate-500 block mb-1">{item.data.period}</span>
						<h3 class="font-bold text-slate-800">
							{item.data.url ? <a href={item.data.url} class="hover:text-blue-600" target="_blank" rel="noopener noreferrer">{item.data.institution}</a> : item.data.institution}
						</h3>
						<p class="text-sm text-slate-600">{item.data.department}</p>
					</div>
				))}
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-bold text-slate-900 mb-6 pb-2 border-b border-slate-200">職歴</h2>
			<div class="space-y-6">
				{experience.map(item => (
					<div class="relative pl-4 border-l-2 border-slate-200">
						<span class="text-sm text-slate-500 block mb-1">{item.data.period}</span>
						<h3 class="font-bold text-slate-800">
							{item.data.url ? <a href={item.data.url} class="hover:text-blue-600" target="_blank" rel="noopener noreferrer">{item.data.company}</a> : item.data.company}
						</h3>
						<p class="text-sm text-slate-600 mb-2">{item.data.role}</p>
						{item.data.description && <p class="text-xs text-slate-500">{item.data.description}</p>}
					</div>
				))}
			</div>
		</section>
	</div>

	{/* Achievements Section */}
	<section class="mb-16">
		<h2 class="text-2xl font-bold text-slate-900 mb-6 pb-2 border-b border-slate-200">資格・受賞・発表</h2>
		
		<div class="space-y-8">
			<div>
				<h3 class="font-bold text-slate-800 mb-4 flex items-center text-lg">
					<span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>
					資格
				</h3>
				<ul class="space-y-4 text-slate-700">
					{certifications.map((item: any) => (
						<li class="flex flex-col sm:flex-row sm:justify-between items-start gap-1 border-l-2 border-blue-100 pl-4 group">
							<div class="flex flex-col gap-1">
                <span class="text-sm flex items-center gap-1">
                  {item.description ? (
                    <button class="modal-trigger text-left hover:text-blue-600 transition-colors font-medium" data-modal-id={`modal-${item.id}`}>
                      {item.name}
                    </button>
                  ) : (
                    item.url ? <a href={item.url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors font-medium">{item.name}</a> : <span class="font-medium">{item.name}</span>
                  )}
                  {item.url && !item.description && <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>}
                </span>
							  {item.issuer && <span class="text-xs text-slate-500">{item.issuer}</span>}
              </div>
              {item.date && <span class="text-xs text-slate-400 whitespace-nowrap">{item.date}</span>}
						</li>
					))}
				</ul>
			</div>

			<div>
				<h3 class="font-bold text-slate-800 mb-4 flex items-center text-lg">
					<span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>
					受賞
				</h3>
				<ul class="space-y-3">
					{awards.map((item: any) => (
						<li class="flex flex-col sm:flex-row sm:justify-between items-start gap-1 border-l-2 border-orange-100 pl-4 group">
							<span class="text-sm text-slate-700 flex items-center gap-1">
								{item.description ? (
                  <button class="modal-trigger text-left hover:text-blue-600 transition-colors font-medium" data-modal-id={`modal-${item.id}`}>
                    {item.title}
                  </button>
                ) : (
                  item.url ? <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">{item.title}</a> : item.title
                )}
                {item.url && !item.description && <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>}
							</span>
							<span class="text-xs text-slate-400 whitespace-nowrap">{item.date}</span>
						</li>
					))}
				</ul>
			</div>

			<div>
				<h3 class="font-bold text-slate-800 mb-4 flex items-center text-lg">
					<span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>
					発表
				</h3>
				<ul class="space-y-4">
					{presentations.map((item: any) => (
						<li class="flex flex-col gap-1 border-l-2 border-green-100 pl-4 group">
							<span class="text-sm font-medium text-slate-700 flex items-center gap-1">
								{item.description ? (
                  <button class="modal-trigger text-left hover:text-blue-600 transition-colors" data-modal-id={`modal-${item.id}`}>
                    {item.title}
                  </button>
                ) : (
                  item.url ? <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">{item.title}</a> : item.title
                )}
                {item.url && !item.description && <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>}
							</span>
							<span class="text-xs text-slate-500">{item.event}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	{/* Projects Section */}
	<section>
		<h2 class="text-2xl font-bold text-slate-900 mb-6 pb-2 border-b border-slate-200">成果物</h2>
		<div class="grid sm:grid-cols-2 gap-6">
			{sortedProjects.map(project => (
				<button 
          class="modal-trigger text-left bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-all group"
          data-modal-id={`modal-${project.id}`}
        >
					<h3 class="font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">{project.data.title}</h3>
					<p class="text-sm text-slate-600 mb-4 line-clamp-2">{project.data.description}</p>
					<div class="flex flex-wrap gap-2 mb-4">
						{project.data.techStack.map(tech => (
							<span class="px-2 py-1 bg-slate-100 text-slate-600 text-[10px] rounded font-medium uppercase tracking-wider">{tech}</span>
						))}
					</div>
					<div class="text-xs text-blue-600 font-medium opacity-0 group-hover:opacity-100 transition-opacity">詳細を見る &rarr;</div>
				</button>
			))}
		</div>
	</section>

  {/* Modals for All Types */}
  {[...sortedProjects.map(p => ({ id: p.id, title: p.data.title, description: '', Content: p.Content, url: p.data.url, github: p.data.github, techStack: p.data.techStack })), 
    ...certifications, ...awards, ...presentations]
    .filter(item => item.Content || item.description)
    .map(item => (
    <dialog id={`modal-${item.id}`} class="fixed inset-0 m-auto rounded-2xl p-0 backdrop:bg-slate-900/50 w-[calc(100%-2rem)] max-w-2xl h-fit max-h-[90vh] overflow-hidden shadow-2xl border-0 bg-white">
      <div class="flex flex-col h-full max-h-[90vh]">
        <header class="p-6 border-b border-slate-100 flex justify-between items-center sticky top-0 bg-white z-10">
          <h3 class="text-xl font-bold text-slate-900">{item.title || item.name}</h3>
          <button class="close-modal text-slate-400 hover:text-slate-600 p-2" data-modal-id={`modal-${item.id}`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </header>
        <div class="p-8 overflow-y-auto">
          {item.techStack && (
            <div class="flex flex-wrap gap-2 mb-6">
              {item.techStack.map((tech: string) => (
                <span class="px-3 py-1 bg-blue-50 text-blue-700 text-xs rounded-full font-semibold">{tech}</span>
              ))}
            </div>
          )}
          <div class="prose prose-slate max-w-none prose-sm sm:prose-base text-slate-700 whitespace-pre-wrap">
            {item.Content ? <item.Content /> : item.description}
          </div>
          <div class="mt-10 flex gap-4 border-t border-slate-100 pt-6">
            {item.github && (
              <a href={item.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-slate-900 text-white rounded-lg text-sm font-medium hover:bg-slate-800 transition-colors">
                GitHub
              </a>
            )}
            {item.url && (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                {item.github ? 'Live Demo' : '関連リンク'}
              </a>
            )}
          </div>
        </div>
      </div>
    </dialog>
  ))}
</Layout>

<script>
  // Modal handling
  const triggers = document.querySelectorAll('.modal-trigger');
  const closeButtons = document.querySelectorAll('.close-modal');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const modalId = trigger.getAttribute('data-modal-id');
      const modal = document.getElementById(modalId!) as HTMLDialogElement;
      if (modal) {
        modal.showModal();
        document.body.style.overflow = 'hidden';
      }
    });
  });

  closeButtons.forEach(button => {
    button.addEventListener('click', () => {
      const modalId = button.getAttribute('data-modal-id');
      const modal = document.getElementById(modalId!) as HTMLDialogElement;
      if (modal) {
        modal.close();
        document.body.style.overflow = '';
      }
    });
  });

  // Close on backdrop click
  const dialogs = document.querySelectorAll('dialog');
  dialogs.forEach(dialog => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        dialog.close();
        document.body.style.overflow = '';
      }
    });
  });
</script>
